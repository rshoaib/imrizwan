# Force LF line endings repo-wide. Prevents Windows-side editors from re-saving
# files with CRLF and producing whitespace-only diffs that block clean commits.
* text=auto eol=lf

# Explicit per-extension pins for the file types the SEO pipeline touches most.
*.md   text eol=lf
*.mdx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.xml  text eol=lf
*.svg  text eol=lf
*.txt  text eol=lf

# Binary files — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.pdf  binary
